---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const fmt = (d) => new Intl.DateTimeFormat('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);
---
<Base
  title="대한민국 정부지원금·복지 혜택 가이드"
  description="부모급여, 기초연금, 근로장려금 등 복잡한 정부지원금과 복지 제도를 정확하고 알기 쉽게 정리합니다. 자격, 금액, 신청 방법을 한눈에."
>
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">정확하게, 쉽게</p>
      <h1>받을 수 있는 혜택,<br />놓치지 않게</h1>
      <p>복잡하고 자주 바뀌는 정부지원금과 복지 제도. 자격·금액·신청 방법을 정확하게 정리해 드립니다.</p>
      <div class="chips">
        <a class="chip" href="/category/childcare">육아·출산</a>
        <a class="chip" href="/category/senior">노후·연금</a>
        <a class="chip" href="/category/living">생활복지</a>
      </div>
    </div>
  </section>

  <div class="wrap-wide">
    <span class="sec-label">최근 정리한 혜택</span>
    <div class="post-grid">
      {posts.map((post) => (
        <a href={`/posts/${post.id}/`} class="card">
          <span class="cat">{post.data.category}</span>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <div class="meta">{fmt(post.data.pubDate)}</div>
        </a>
      ))}
    </div>
  </div>
</Base>
