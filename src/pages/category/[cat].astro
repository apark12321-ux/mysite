---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const labels = {
    start: '시작하기',
    review: '경험·리뷰',
  };
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return Object.entries(labels).map(([key, label]) => ({
    params: { cat: key },
    props: { label, posts: posts.filter((p) => p.data.category === label) },
  }));
}

const { label, posts } = Astro.props;
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const fmt = (d) => new Intl.DateTimeFormat('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);
---
<Base title={label} description={`${label} 카테고리의 글 모음`}>
  <section class="hero" style="padding:56px 0 32px">
    <div class="wrap"><h1>{label}</h1></div>
  </section>
  <div class="wrap-wide">
    <div class="post-grid">
      {sorted.length === 0 && <p style="color:var(--ink-faint)">아직 글이 없습니다.</p>}
      {sorted.map((post) => (
        <a href={`/posts/${post.id}/`} class="card">
          <div class="emoji">{post.data.heroEmoji}</div>
          <span class="cat">{post.data.category}</span>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <div class="meta">{fmt(post.data.pubDate)}</div>
        </a>
      ))}
    </div>
  </div>
</Base>
