---
const nav = [
  { href: '/', label: '홈' },
  { href: '/category/start', label: '시작하기' },
  { href: '/category/review', label: '경험·리뷰' },
  { href: '/about', label: '소개' },
  { href: '/contact', label: '문의' },
];
---
<header class="site-header">
  <div class="bar">
    <a href="/" class="brand" style="text-decoration:none">곁들<span>이</span></a>
    <button class="menu-toggle" aria-label="메뉴">☰</button>
    <nav class="nav">
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
    </nav>
  </div>
</header>
